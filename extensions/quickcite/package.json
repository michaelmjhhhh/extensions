{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "quickcite",
  "title": "QuickCite",
  "description": "Convert URLs or DOIs to properly formatted MLA citations with metadata extraction",
  "icon": "command-icon.png",
  "author": "jinghan_ma",
  "license": "MIT",
  "platforms": [
    "macOS"
  ],
  "dependencies": {
    "@raycast/api": "^1.104.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "^22.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.0"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  },
  "commands": [
    {
      "name": "convert-url-to-mla",
      "title": "Convert to MLA Citation",
      "description": "Generate an MLA citation from a URL or DOI",
      "mode": "view"
    }
  ],
  "categories": [
    "Productivity"
  ]
}
